{
	"name": "routing-simulator",
	"private": true,
	"version": "0.0.1",
	"type": "module",
	"svelte": "src/lib/components/index.js",
	"scripts": {
		"dev": "vite dev",
		"build": "vite build",
		"preview": "vite preview",
		"prepare": "svelte-kit sync || echo ''",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"format": "prettier --write .",
		"lint": "prettier --check . && eslint .",
		"test": "vitest",
		"test:run": "vitest run",
		"test:ui": "vitest --ui",
		"test:e2e": "playwright test",
		"test:e2e:ui": "playwright test --ui",
		"test:e2e:debug": "playwright test --debug",
		"doc:gen": "node scripts/sveld-docs.mjs",
		"doc:ts": "typedoc --options typedoc.json",
		"docs:dev": "npm run doc:gen && npm run doc:ts && vitepress dev docs",
		"docs:build": "npm run doc:gen && npm run doc:ts && vitepress build docs",
		"docs:preview": "vitepress preview docs"
	},
	"devDependencies": {
		"@eslint/compat": "^1.4.0",
		"@eslint/js": "^9.38.0",
		"@playwright/test": "^1.58.1",
		"@sveltejs/adapter-auto": "^7.0.0",
		"@sveltejs/adapter-static": "^3.0.10",
		"@sveltejs/kit": "^2.47.1",
		"@sveltejs/vite-plugin-svelte": "^6.2.1",
		"@tailwindcss/vite": "^4.1.14",
		"@types/node": "^22",
		"@vitest/coverage-v8": "^4.0.18",
		"@vitest/ui": "^4.0.18",
		"eslint": "^9.38.0",
		"eslint-config-prettier": "^10.1.8",
		"eslint-plugin-svelte": "^3.12.4",
		"globals": "^16.4.0",
		"patch-package": "^8.0.1",
		"prettier": "^3.6.2",
		"prettier-plugin-svelte": "^3.4.0",
		"prettier-plugin-tailwindcss": "^0.7.1",
		"sveld": "^0.24.0",
		"svelte": "^5.41.0",
		"svelte-check": "^4.3.3",
		"tailwindcss": "^4.1.14",
		"typedoc": "^0.28.0",
		"typedoc-plugin-markdown": "^4.9.0",
		"typescript": "5.8.3",
		"typescript-eslint": "^8.46.1",
		"vite": "^7.1.10",
		"vitepress": "^1.3.1",
		"vitest": "^4.0.18"
	},
	"dependencies": {
		"@xyflow/svelte": "^1.4.1"
	}
}
